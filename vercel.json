{
  "outputDirectory": "logistics_system/web",
  "functions": {
    "logistics_system/api/main.py": {
      "runtime": "python3.12"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/logistics_system/api/main.py" },
    { "source": "/", "destination": "/index.html" },
    { "source": "/(.*)", "destination": "/$1" }
  ]
}
